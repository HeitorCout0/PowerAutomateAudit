                      "Succeeded"
                    ]
                  }
                },
                "Acrescentar_a_variavel_de_matriz": {
                  "type": "AppendToArrayVariable",
                  "inputs": {
                    "name": "varItensDetalhados",
                    "value": {
                      "managerEmail": "@{outputs('Compor_-_Manager_email')}",
                      "resultCenterName": "@{first(actions('Matriz_do_filtro_-_Buscar_gestor_do_responsavel')?['outputs']?['body'])?['resultCenterName']}",
                      "cardId": "@{outputs('Get_work_item_details_-_Pegar_detalhes_dos_cards_divergentes')?['body/id']}",
                      "titulo": "@{outputs('Get_work_item_details_-_Pegar_detalhes_dos_cards_divergentes')?['body/fields/System_Title']}",
                      "responsavel": "@{outputs('Get_work_item_details_-_Pegar_detalhes_dos_cards_divergentes')?['body/fields/System_AssignedTo']}",
                      "htmlTabela": "@{outputs('Compose_-_Compor_tabela')}"
