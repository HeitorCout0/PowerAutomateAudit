                },
                "Enviar_uma_solicitacao_HTTP_-_Verificar_NC_existente": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "parameters": {
                      "account": "YOUR_DEVOPS_ORG",
                      "parameters/Method": "POST",
                      "parameters/Uri": "https://dev.azure.com/YOUR_DEVOPS_ORG/YOUR_MANAGEMENT_PROJECT/_apis/wit/wiql?api-version=7.1",
                      "parameters/Body": "{\"query\": \"SELECT [System.Id] FROM workitems WHERE [System.TeamProject] = 'YOUR_MANAGEMENT_PROJECT' AND [System.WorkItemType] = 'Non compliance' AND [System.State] NOT IN ('Closed','Removed') AND [System.AssignedTo] = '@{items('Aplicar_a_cada_-_Manager_unico')}' AND [System.Parent] = @{variables('varAuditCardId')} AND ([System.Title] = 'YOUR_NC_TITLE_V1' OR [System.Title] = 'YOUR_NC_TITLE_V2')\"}"
                    },
                    "host": {
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_visualstudioteamservices",
                      "operationId": "HttpRequest",
                      "connectionName": "shared_visualstudioteamservices"
                    }
                  },
                  "runAfter": {
