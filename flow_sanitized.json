        "Itens_que_nao_estao_BPG": {
          "type": "Scope",
          "actions": {
            "Apply_to_each_-_Itens_VSTS": {
              "type": "Foreach",
              "foreach": "@body('Select_IDs_VSTS')",
              "actions": {
