        "BPG": {
          "type": "Scope",
          "actions": {
            "Executar_uma_consulta_em_um_conjuntos_de_dados_-_Mes": {
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "groupid": "YOUR_POWERBI_WORKSPACE_GROUP_ID",
                  "datasetid": "YOUR_POWERBI_DATASET_ID",
                  "specification/query": "DEFINE\n\tVAR __DS0FilterTable = \n\t\tTREATAS(\n\t\t\t{\"'measure'[YOUR_THROUGHPUT_MEASURE]\"},\n\t\t\t'YOUR_THROUGHPUT_TABLE'[YOUR_THROUGHPUT_FIELD]\n\t\t)\n\n\tVAR __DS0FilterTable2 = \n\t\tTREATAS({TRUE}, 'dim_result_center_process'[set_process])\n\n\tVAR __DS0FilterTable3 = \n\t\tTREATAS(\n\t\t\t{(\"YOUR_ECOSYSTEM\", \"YOUR_BUSINESS_UNIT\")},\n\t\t\t'dim_result_center_process'[ecosystem],\n\t\t\t'dim_result_center_process'[business_unit_name]\n\t\t)\n\n\tVAR __DS0FilterTable4 = \n\t\tTREATAS(\n\t\t\t{(@{outputs('Compor_Ano')}, \"@{outputs('Compor_-_Trimestre')}\", \"@{outputs('Compor_-_Mes_portugues')}\")},\n\t\t\t'YOUR_DATE_TABLE_ID'[Ano],\n\t\t\t'YOUR_DATE_TABLE_ID'[Trimestre],\n\t\t\t'YOUR_DATE_TABLE_ID'[Mes]\n\t\t)\n\n\tVAR __DS0Core = \n\t\tSUMMARIZECOLUMNS(\n\t\t\tROLLUPADDISSUBTOTAL(\n\t\t\t\tROLLUPGROUP(\n\t\t\t\t\t'fact_workitem'[code_source],\n\t\t\t\t\t'fact_workitem'[code_target],\n\t\t\t\t\t'fact_workitem'[status],\n\t\t\t\t\t'fact_workitem'[closed_date],\n\t\t\t\t\t'fact_workitem'[created_date],\n\t\t\t\t\t'fact_workitem'[target_date],\n\t\t\t\t\t'fact_workitem'[title],\n\t\t\t\t\t'fact_workitem'[user_account]\n\t\t\t\t), \"IsGrandTotalRowTotal\"\n\t\t\t),\n\t\t\t__DS0FilterTable,\n\t\t\t__DS0FilterTable2,\n\t\t\t__DS0FilterTable3,\n\t\t\t__DS0FilterTable4,\n\t\t\t\"m_total_deliveries\", 'measure'[m_total_deliveries]\n\t\t)\n\n\t// --- Adicionando coluna de ID separando pelo \":\" ---\n\tVAR __DS0CoreWithID = \n\t\tADDCOLUMNS(\n\t\t\t__DS0Core,\n\t\t\t\"ID\", \n\t\t\tVAR _source = 'fact_workitem'[code_source]\n\t\t\tVAR _colonPos = FIND(\":\", _source, 1, 0)\n\t\t\tRETURN\n\t\t\t\tIF(_colonPos > 0, MID(_source, _colonPos + 1, LEN(_source)), BLANK())\n\t\t)\n\t// --------------------------------------------------\n\n\tVAR __DS0PrimaryWindowed = \n\t\tTOPN(\n\t\t\t502,\n\t\t\t__DS0CoreWithID,\n\t\t\t[IsGrandTotalRowTotal],\n\t\t\t0,[m_total_deliveries],\n\t\t\t0,\n\t\t\t'fact_workitem'[code_source],\n\t\t\t1,\n\t\t\t'fact_workitem'[code_target],\n\t\t\t1,\n\t\t\t'fact_workitem'[status],\n\t\t\t1,\n\t\t\t'fact_workitem'[closed_date],\n\t\t\t1,\n\t\t\t'fact_workitem'[created_date],\n\t\t\t1,\n\t\t\t'fact_workitem'[target_date],\n\t\t\t1,\n\t\t\t'fact_workitem'[title],\n\t\t\t1,\n\t\t\t'fact_workitem'[user_account],\n\t\t\t1\n\t\t)\n\nEVALUATE\n\t__DS0PrimaryWindowed\n\nORDER BY\n\t[IsGrandTotalRowTotal] DESC,[m_total_deliveries] DESC,\n\t'fact_workitem'[code_source],\n\t'fact_workitem'[code_target],\n\t'fact_workitem'[status],\n\t'fact_workitem'[closed_date],\n\t'fact_workitem'[created_date],\n\t'fact_workitem'[target_date],\n\t'fact_workitem'[title],\n\t'fact_workitem'[user_account]",
                  "specification/serializerSettings/includeNulls": true
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_powerbi",
                  "operationId": "ExecuteDatasetQuery",
                  "connectionName": "shared_powerbi"
                }
              }
            },
            "Select_IDs_BPG": {
