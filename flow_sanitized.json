                      "ID": "@outputs('Get_work_item_details_-_Pegar_detalhes_dos_cards_divergentes')?['body/id']",
                      "Titulo": "@outputs('Get_work_item_details_-_Pegar_detalhes_dos_cards_divergentes')?['body/fields/System_Title']",
                      "Responsavel": "@outputs('Get_work_item_details_-_Pegar_detalhes_dos_cards_divergentes')?['body/fields/System_AssignedTo']"
                    }
                  },
                  "runAfter": {
                    "Get_work_item_details_-_Pegar_detalhes_dos_cards_divergentes": [
                      "Succeeded"
                    ]
                  }
                },
                "Create_HTML_table_-_Criar_tabela_em_HTML_com_cards_divergentes": {
                  "type": "Table",
                  "inputs": {
                    "from": "@body('Select_-_Itens_da_querie_detalhes_de_todos_os_itens_divergentes')",
                    "format": "HTML"
                  },
                  "runAfter": {
                    "Select_-_Itens_da_querie_detalhes_de_todos_os_itens_divergentes": [
                      "Succeeded"
                    ]
                  }
                },
                "Compose_-_Compor_tabela": {
                  "type": "Compose",
                  "inputs": "<style>\n  table {\n    border: 1px solid #1C6EA4;\n    background-color: #EEEEEE;\n    width: 100%;\n    text-align: center;\n    border-collapse: collapse;\n  }\n  table td, table th {\n    border: 1px solid #AAAAAA;\n    padding: 3px 10px;\n    white-space: nowrap;\n  }\n  table tbody td {\n    font-size: 13px;\n  }\n  table thead {\n    background: #1C6EA4;\n    border-bottom: 2px solid #444444;\n  }\n  table thead th {\n    font-size: 15px;\n    font-weight: bold;\n    color: #000000;\n    border-left: 2px solid #D0E4F5;\n  }\n  table thead th:first-child {\n    border-left: none;\n  }\n</style>\n@{body('Create_HTML_table_-_Criar_tabela_em_HTML_com_cards_divergentes')}",
                  "runAfter": {
                    "Create_HTML_table_-_Criar_tabela_em_HTML_com_cards_divergentes": [
                      "Succeeded"
                    ]
                  }
                },
                "Matriz_do_filtro_-_Buscar_gestor_do_responsavel": {
                  "type": "Query",
                  "inputs": {
                    "from": "@body('Selecionar_-_Seleciona_email_CC_BU_e_email_do_gestor')",
                    "where": "@equals(item()?['email'],outputs('Get_work_item_details_-_Pegar_detalhes_dos_cards_divergentes')?['body/fields/Vsts_AssignedToEmail'])"
                  },
                  "runAfter": {
                    "Compose_-_Compor_tabela": [
                      "Succeeded"
                    ]
                  }
                },
                "Compor_-_Manager_email": {
                  "type": "Compose",
                  "inputs": "@first(actions('Matriz_do_filtro_-_Buscar_gestor_do_responsavel')?['outputs']?['body'])?['managerEmail']",
                  "runAfter": {
