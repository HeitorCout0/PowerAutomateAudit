        "VSTS": {
          "type": "Scope",
          "actions": {
            "Enviar_uma_solicitacao_HTTP_ao_Azure_DevOps": {
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "account": "YOUR_DEVOPS_ORG",
                  "parameters/Method": "POST",
                  "parameters/Uri": "https://dev.azure.com/YOUR_DEVOPS_ORG/YOUR_SOURCE_PROJECT/_apis/wit/wiql?api-version=7.1",
                  "parameters/Body": "{\"query\": \"SELECT [System.Id],[System.WorkItemType],[System.Title],[System.AssignedTo],[System.State],[Custom.YOUR_OTD_FIELD],[Microsoft.VSTS.Scheduling.TargetDate],[Microsoft.VSTS.Common.ClosedDate] FROM workitems WHERE [System.TeamProject] = 'YOUR_SOURCE_PROJECT' AND [System.WorkItemType] = 'User Story' AND [System.State] <> 'Removed' AND [Custom.YOUR_DELIVERY_FLAG] = 'SIM' AND [Microsoft.VSTS.Common.ClosedDate] >= @startOfMonth - 1 AND [Microsoft.VSTS.Common.ClosedDate] < @startOfMonth AND [Custom.YOUR_PROJECT_FIELD] IN ('YOUR_PROJECT_1','YOUR_PROJECT_2','YOUR_PROJECT_3') AND NOT [System.AreaPath] IN ('YOUR_SOURCE_PROJECT\\\\YOUR_EXCLUDED_AREA_1','YOUR_SOURCE_PROJECT\\\\YOUR_EXCLUDED_AREA_2') ORDER BY [System.Id]\"}"
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_visualstudioteamservices",
                  "operationId": "HttpRequest",
                  "connectionName": "shared_visualstudioteamservices"
                }
              }
            },
            "Select_IDs_VSTS": {
              "type": "Select",
              "inputs": {
                "from": "@body('Enviar_uma_solicitacao_HTTP_ao_Azure_DevOps')?['workItems']",
