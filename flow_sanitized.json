                }
              }
            },
            "Compose_-_Resultado_itens_que_nao_estao_no_VSTS": {
              "type": "Compose",
              "inputs": "@variables('varItensFaltandoVSTS')",
              "runAfter": {
                "Apply_to_each_-_Itens_BPG": [
                  "Succeeded"
                ]
              }
