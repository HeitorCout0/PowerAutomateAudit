            "Para_cada_item_retornado": {
              "type": "Foreach",
              "foreach": "@outputs('Compose_-_IDs_Combinados')",
              "actions": {
                "Get_work_item_details_-_Pegar_detalhes_dos_cards_divergentes": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "parameters": {
                      "account": "YOUR_DEVOPS_ORG",
                      "project": "YOUR_SOURCE_PROJECT",
                      "typeName": "User Story",
                      "id": "@int(items('Para_cada_item_retornado'))"
                    },
                    "host": {
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_visualstudioteamservices",
                      "operationId": "GetWorkItemDetails",
                      "connectionName": "shared_visualstudioteamservices"
                    }
                  }
                },
                "Select_-_Itens_da_querie_detalhes_de_todos_os_itens_divergentes": {
                  "type": "Select",
                  "inputs": {
                    "from": "@createArray(outputs('Get_work_item_details_-_Pegar_detalhes_dos_cards_divergentes')?['body'])",
