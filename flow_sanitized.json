                  }
                },
                "Compor_-_NC_Count": {
                  "type": "Compose",
                  "inputs": "@length(body('Enviar_uma_solicitacao_HTTP_-_Verificar_NC_existente')?['workItems'])",
                  "runAfter": {
                    "Enviar_uma_solicitacao_HTTP_-_Verificar_NC_existente": [
                      "Succeeded"
                    ]
                  }
                },
                "Condicao_-_Se_NC_ja_existe": {
                  "type": "If",
                  "expression": {
                    "and": [
                      {
                        "equals": [
                          "@outputs('Compor_-_NC_Count')",
                          0
                        ]
                      }
                    ]
                  },
                  "actions": {
                    "Criar_um_item_de_trabalho_NC": {
                      "type": "OpenApiConnection",
                      "inputs": {
                        "parameters": {
                          "account": "YOUR_DEVOPS_ORG",
                          "project": "YOUR_MANAGEMENT_PROJECT",
                          "type": "Non compliance",
                          "workItem/title": "YOUR_NC_TITLE_V2",
                          "workItem/description": "<p class=\"editor-paragraph\">@{body('Criar_Tabela_HTML_-_Cards_do_manager')}</p>",
                          "workItem/area": "YOUR_MANAGEMENT_PROJECT\\YOUR_AREA_PATH\\@{if(or(equals(first(body('Matriz_do_filtro_-_Cards_do_Manager_unico'))['resultCenterName'],'YOUR_RESULT_CENTER_1'),or(equals(first(body('Matriz_do_filtro_-_Cards_do_Manager_unico'))['resultCenterName'],'YOUR_RESULT_CENTER_2'),equals(first(body('Matriz_do_filtro_-_Cards_do_Manager_unico'))['resultCenterName'],'YOUR_RESULT_CENTER_3'))),first(body('Matriz_do_filtro_-_Cards_do_Manager_unico'))['resultCenterName'],'')}",
                          "workItem/linkUrl": "https://dev.azure.com/YOUR_DEVOPS_ORG/YOUR_MANAGEMENT_PROJECT/_workitems/edit/@{variables('varAuditCardId')}",
                          "workItem/linkType": "Hierarchy-reverse",
                          "workItem/dynamicFields/System.AssignedTo": "@items('Aplicar_a_cada_-_Manager_unico')"
                        },
                        "host": {
                          "apiId": "/providers/Microsoft.PowerApps/apis/shared_visualstudioteamservices",
                          "operationId": "CreateWorkItem",
                          "connectionName": "shared_visualstudioteamservices"
                        }
                      }
                    }
                  },
                  "else": {
                    "actions": {
                      "Atualizar_NC_existente": {
                        "type": "OpenApiConnection",
                        "inputs": {
                          "parameters": {
                            "account": "YOUR_DEVOPS_ORG",
                            "parameters/Method": "PATCH",
                            "parameters/Uri": "https://dev.azure.com/YOUR_DEVOPS_ORG/YOUR_MANAGEMENT_PROJECT/_apis/wit/workitems/@{body('Enviar_uma_solicitacao_HTTP_-_Verificar_NC_existente')?['workItems'][0]['id']}?api-version=7.1",
                            "parameters/Headers": {
                              "Content-Type": "application/json-patch+json"
                            },
                            "parameters/Body": "[{\"op\": \"replace\",\"path\": \"/fields/System.Description\",\"value\": \"<p>Conforme definido pela unidade, a quantidade de entregas do sistema origem deve ser igual ao BPG.<br><br>As entregas abaixo se encontram divergentes do esperado.<br><br>@{body('Criar_Tabela_HTML_-_Cards_do_manager')}</p>\"}]"
                          },
                          "host": {
                            "apiId": "/providers/Microsoft.PowerApps/apis/shared_visualstudioteamservices",
                            "operationId": "HttpRequest",
                            "connectionName": "shared_visualstudioteamservices"
                          }
                        }
                      }
                    }
                  },
                  "runAfter": {
                    "Compor_-_NC_Count": [
                      "Succeeded"
                    ]
                  }
                }
              },
              "runAfter": {
                "Aplicar_a_cada_-_Popular_managers_unicos": [
                  "Succeeded"
                ]
              },
              "runtimeConfiguration": {
                "concurrency": {
                  "repetitions": 1
                }
              }
            },
            "Aplicar_a_cada_-_Popular_managers_unicos": {
              "type": "Foreach",
              "foreach": "@variables('varItensDetalhados')",
              "actions": {
                "Condicao_1": {
                  "type": "If",
                  "expression": {
                    "and": [
                      {
                        "equals": [
                          "@contains(variables('varManagersUnicos'), item()['managerEmail'])",
                          false
                        ]
                      }
                    ]
                  },
                  "actions": {
                    "Acrescentar_a_variavel_de_matriz_1": {
                      "type": "AppendToArrayVariable",
                      "inputs": {
                        "name": "varManagersUnicos",
                        "value": "@item()['managerEmail']"
                      }
                    }
                  },
                  "else": {
                    "actions": {}
                  }
                }
              },
              "runAfter": {
                "Para_cada_item_retornado": [
                  "Succeeded"
                ]
              },
              "runtimeConfiguration": {
                "concurrency": {
                  "repetitions": 1
                }
              }
            }
          },
          "runAfter": {
            "Escopo_-_Lista_de_lideres_para_NC": [
              "Succeeded"
            ]
          }
        },
        "Compose_-_Competencia_Titulo": {
          "type": "Compose",
          "inputs": "@concat('Auditoria BPG - YOUR_PROJECT_NAME - ', outputs('Compose_-_Competencia_Atual'))",
          "runAfter": {
            "Compose_-_Competencia_Atual": [
              "Succeeded"
            ]
          }
        },
        "Initialize_variable_-_varItensDetalhados": {
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "varItensDetalhados",
                "type": "array"
              }
            ]
          },
          "runAfter": {
            "Compose_-_Competencia_Titulo": [
              "Succeeded"
            ]
          }
        },
        "Scope_-_Card_Audit": {
          "type": "Scope",
          "actions": {
            "Send_an_HTTP_request_to_Azure_DevOps_-_Buscar_card_Audit": {
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "account": "YOUR_DEVOPS_ORG",
                  "parameters/Method": "POST",
                  "parameters/Uri": "https://dev.azure.com/YOUR_DEVOPS_ORG/YOUR_MANAGEMENT_PROJECT/_apis/wit/wiql?api-version=7.1",
                  "parameters/Body": "{\"query\": \"SELECT [System.Id] FROM workitems WHERE [System.TeamProject] = 'YOUR_MANAGEMENT_PROJECT' AND [System.WorkItemType] = 'Audit' AND [System.State] NOT IN ('Closed','Removed') AND [System.Title] CONTAINS 'Auditoria BPG' AND [System.Title] CONTAINS 'YOUR_PROJECT_NAME' AND [System.Title] CONTAINS '@{outputs('Compor_-_Mes_portugues')}'\"}"
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_visualstudioteamservices",
                  "operationId": "HttpRequest",
                  "connectionName": "shared_visualstudioteamservices"
                },
                "retryPolicy": {
                  "type": "none"
                }
              }
            },
            "Compose_-_Audit_Count": {
              "type": "Compose",
              "inputs": "@length(body('Send_an_HTTP_request_to_Azure_DevOps_-_Buscar_card_Audit')?['workItems'])",
              "runAfter": {
                "Send_an_HTTP_request_to_Azure_DevOps_-_Buscar_card_Audit": [
                  "Succeeded"
                ]
              }
            },
            "Condition_-_Condicao_se_ja_existe_card_Audit": {
              "type": "If",
              "expression": {
                "and": [
                  {
                    "greater": [
                      "@outputs('Compose_-_Audit_Count')",
                      0
                    ]
                  }
                ]
              },
              "actions": {
                "Compose_-_card_de_auditoria_existente": {
                  "type": "Compose",
                  "inputs": "@body('Send_an_HTTP_request_to_Azure_DevOps_-_Buscar_card_Audit')?['workItems'][0]['id']"
                },
                "Definir_variavel": {
                  "type": "SetVariable",
                  "inputs": {
                    "name": "varAuditCardId",
                    "value": "@outputs('Compose_-_card_de_auditoria_existente')"
                  },
                  "runAfter": {
                    "Compose_-_card_de_auditoria_existente": [
                      "Succeeded"
                    ]
                  }
                }
              },
              "else": {
                "actions": {
                  "Create_a_work_item_-_Criar_card_da_auditoria": {
                    "type": "OpenApiConnection",
                    "inputs": {
                      "parameters": {
                        "account": "YOUR_DEVOPS_ORG",
                        "project": "YOUR_MANAGEMENT_PROJECT",
                        "type": "Audit",
                        "workItem/title": "@outputs('Compose_-_Competencia_Titulo')",
                        "workItem/description": "<p class=\"editor-paragraph\">Auditoria BPG @{outputs('Compose_-_Competencia_Atual')}<br><br>Escopo:<br><br>Custo<br>Prazo<br>Avaliacao<br>Esforco<br>Indicadores</p>",
                        "workItem/iteration": "YOUR_MANAGEMENT_PROJECT",
                        "workItem/area": "YOUR_MANAGEMENT_PROJECT\\YOUR_AREA_PATH",
                        "workItem/userEnteredFields": {
                          "YOUR_BU_FIELD": "YOUR_BUSINESS_UNIT_VALUE",
                          "Type": "BPG - YOUR_TEAM_TYPE"
                        }
                      },
                      "host": {
                        "apiId": "/providers/Microsoft.PowerApps/apis/shared_visualstudioteamservices",
                        "operationId": "CreateWorkItem",
                        "connectionName": "shared_visualstudioteamservices"
                      }
                    }
                  },
                  "Compor_-_Card_de_auditoria_criado": {
                    "type": "Compose",
                    "inputs": "@outputs('Create_a_work_item_-_Criar_card_da_auditoria')?['body/id']",
                    "runAfter": {
                      "Create_a_work_item_-_Criar_card_da_auditoria": [
                        "Succeeded"
                      ]
                    }
                  },
                  "Definir_variavel_1": {
                    "type": "SetVariable",
                    "inputs": {
                      "name": "varAuditCardId",
                      "value": "@outputs('Compor_-_Card_de_auditoria_criado')"
                    },
                    "runAfter": {
                      "Compor_-_Card_de_auditoria_criado": [
                        "Succeeded"
                      ]
                    }
                  }
                }
              },
              "runAfter": {
                "Compose_-_Audit_Count": [
                  "Succeeded"
                ]
              }
            }
          },
          "runAfter": {
            "Itens_que_nao_estao_VSTS": [
              "Succeeded"
            ]
          }
        },
        "Terminate": {
          "type": "Terminate",
          "inputs": {
            "runStatus": "Succeeded"
          },
          "runAfter": {
            "Scope_-_Buscar_detalhes_dos_cards_divergentes": [
              "Succeeded"
            ]
          }
        },
        "Compose_-_Competencia_Atual": {
          "type": "Compose",
          "inputs": "@toUpper(concat(substring(formatDateTime(addToTime(utcNow(),-1,'Month'),'MMM'),0,3),'_',substring(formatDateTime(addToTime(utcNow(),-1,'Month'),'yy'),0,2)))",
          "runAfter": {}
        },
        "Escopo_-_Lista_de_lideres_para_NC": {
          "type": "Scope",
          "actions": {
            "Enviar_uma_solicitacao_HTTP_ao_SharePoint": {
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "dataset": "https://YOUR_TENANT.sharepoint.com/sites/YOUR_SHAREPOINT_SITE",
                  "parameters/method": "GET",
                  "parameters/uri": "_api/web/lists/getbytitle('YOUR_RESULT_CENTER_LIST')/items?$select=ID,JSON&$top=1"
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_sharepointonline",
                  "operationId": "HttpRequest",
                  "connectionName": "shared_sharepointonline"
                }
              }
            },
            "Compor": {
              "type": "Compose",
              "inputs": "@body('Enviar_uma_solicitacao_HTTP_ao_SharePoint')?['d']?['results'][0]?['JSON']",
              "runAfter": {
                "Enviar_uma_solicitacao_HTTP_ao_SharePoint": [
                  "Succeeded"
                ]
              }
            },
            "Selecionar_-_Seleciona_email_CC_BU_e_email_do_gestor": {
              "type": "Select",
              "inputs": {
                "from": "@json(outputs('Compor'))",
                "select": {
                  "email": "@item()['email']",
                  "resultCenterName": "@item()['resultCenterName']",
                  "businessUnitName": "@item()['businessUnitName']",
                  "managerEmail": "@item()['managerEmail']"
                }
              },
              "runAfter": {
                "Compor": [
                  "Succeeded"
                ]
              }
            }
          },
          "runAfter": {
            "Condition_-_Se_a_quantidade_de_itens_divergentes_for_igual_a_zero": [
              "Succeeded"
            ]
          }
        },
        "Inicializar_variavel_-_varAuditCardId": {
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "varAuditCardId",
                "type": "integer"
              }
            ]
          },
          "runAfter": {
            "Inicializar_variavel_-_varManagersUnicos": [
              "Succeeded"
            ]
          }
        },
        "Escopo_-_calculo_de_mes_dinamico": {
          "type": "Scope",
          "actions": {
            "Compor_-_Mes_portugues": {
              "type": "Compose",
              "inputs": "@if(equals(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM'),'01'),'janeiro',if(equals(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM'),'02'),'fevereiro',if(equals(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM'),'03'),'marco',if(equals(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM'),'04'),'abril',if(equals(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM'),'05'),'maio',if(equals(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM'),'06'),'junho',if(equals(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM'),'07'),'julho',if(equals(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM'),'08'),'agosto',if(equals(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM'),'09'),'setembro',if(equals(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM'),'10'),'outubro',if(equals(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM'),'11'),'novembro','dezembro')))))))))))"
            },
            "Compor_-_Trimestre": {
              "type": "Compose",
              "inputs": "@concat('Trim ', if(lessOrEquals(int(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM')),3),'1',if(lessOrEquals(int(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM')),6),'2',if(lessOrEquals(int(formatDateTime(addToTime(utcNow(),-1,'Month'),'MM')),9),'3','4'))))",
              "runAfter": {
                "Compor_-_Mes_portugues": [
                  "Succeeded"
                ]
              }
            },
            "Compor_Ano": {
              "type": "Compose",
              "inputs": "@int(formatDateTime(addToTime(utcNow(),-1,'Month'),'yyyy'))",
              "runAfter": {
                "Compor_-_Trimestre": [
                  "Succeeded"
                ]
              }
            }
          },
          "runAfter": {
            "Initialize_variable_-_Itens_Faltando_VSTS": [
              "Succeeded"
            ]
          }
        },
        "Inicializar_variavel_-_varManagersUnicos": {
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "varManagersUnicos",
                "type": "array"
              }
            ]
          },
          "runAfter": {
            "Initialize_variable_-_varItensDetalhados": [
              "Succeeded"
            ]
          }
        }
      }
    },
    "displayName": "[YOUR_PROJECT_NAME] - Se a quantidade de entregas do sistema origem é igual ao BPG",
    "environment": {
      "name": "YOUR_ENVIRONMENT_ID"
    },
    "workflowEntityId": "YOUR_WORKFLOW_ENTITY_ID"
  },
  "name": "YOUR_WORKFLOW_ENTITY_ID"
}
